# Google Sheet CSV URL — published CSV link from the DU cutoffs Google Sheet
GOOGLE_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv

# Groq API key — get one at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Google Apps Script web app URL — receives tracking/lead/submission data
# The script should route to different sheet tabs based on the "sheet" field:
#   sheet="visits"      → Visits tab (page views, step tracking)
#   sheet="leads"       → Leads tab (gate completions with name/phone)
#   sheet="submissions" → Submissions tab (full form submissions with scores)
TRACK_SHEET_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
